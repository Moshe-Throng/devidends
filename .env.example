# ============================================
# Devidends Environment Variables
# ============================================
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude AI ---
ANTHROPIC_API_KEY=

# --- Telegram Bot ---
# Create via @BotFather: /newbot -> devidends_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# Bot username (without @) for Login Widget on web
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# --- Resend (Email) ---
RESEND_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
